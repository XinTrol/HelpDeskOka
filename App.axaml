<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DiplomHelpDeskOka.App"
             xmlns:local="using:DiplomHelpDeskOka"
             xmlns:con="using:DiplomHelpDeskOka.Converters"
             RequestedThemeVariant="Light">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />
    </Application.Styles>

    <Application.Resources>
        <con:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <con:BoolToStatusTextConverter x:Key="BoolToStatusText"/>
        <con:BoolToStatusColorConverter x:Key="BoolToStatusColor"/>
    </Application.Resources>
</Application>