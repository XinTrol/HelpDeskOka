<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="950"
			 x:Class="DiplomHelpDeskOka.Views.AddOrEditUserScreenView"

			 xmlns:vm="clr-namespace:DiplomHelpDeskOka.ViewModels"
			 x:DataType="vm:AddOrEditUserScreenViewModel">
	<Grid RowDefinitions="Auto, Auto, *" ColumnDefinitions="200, *">

		<!-- HEADER -->
		<Border Grid.Row="0" Grid.ColumnSpan="2"
				Background="White" Height="70" Padding="20,10">
			<Grid ColumnDefinitions="Auto, *, Auto">
				<Image Source="/Assets/Image.png" Height="40"/>
				<StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center">
					<TextBlock Text="{Binding CurrentUser.ShortName}" FontWeight="Bold"/>
					<TextBlock Text="{Binding CurrentUser.Role.Name}" FontSize="12"/>
				</StackPanel>
			</Grid>
		</Border>

		<!-- TITLE -->
		<Border Grid.Row="1" Grid.ColumnSpan="2"
				Background="#C9A86A" Height="60" Padding="20,0">

			<Grid ColumnDefinitions="200,*">
			<!-- Меню -->
			<TextBlock Grid.Column="0" Text="Меню"
					   VerticalAlignment="Center"
					   Foreground="White"
					   FontSize="16"
					   FontWeight="SemiBold"/>

				<!-- Заголовок (Название страницы) -->
				<TextBlock Grid.Column="1"
						   Text="{Binding Title}"
						   HorizontalAlignment="Center"
						   VerticalAlignment="Center"
						   Foreground="White"
						   FontSize="18"
						   FontWeight="Bold"/>
			</Grid>
		</Border>

		<!-- 📚 SIDEBAR -->
		<Border Grid.Row="2"
				Grid.Column="0"
				Background="#F1EFEA"
				Padding="10">

			<StackPanel Spacing="10">

				<Button Content="Главная"
						Height="40"
						Width="160"
						HorizontalAlignment="Left"
						VerticalAlignment="Center"
						HorizontalContentAlignment="Left"
						VerticalContentAlignment="Center"
						Background="Transparent"
						Command="{Binding GoToMainScreenCommand}"/>

				<Border Background="Transparent"
						Padding="10"
						BorderBrush="#C9A86A"
						BorderThickness="3,0,0,0">

					<Button Content="Пользователи"
							Height="40"
							Width="160"
							HorizontalAlignment="Left"
							VerticalAlignment="Center"
							HorizontalContentAlignment="Left"
							VerticalContentAlignment="Center"
							Background="Transparent"/>
				</Border>

				<Button Content="Заявки"
						Height="40"
						Width="160"
						HorizontalAlignment="Left"
						VerticalAlignment="Center"
						HorizontalContentAlignment="Left"
						VerticalContentAlignment="Center"
						Background="Transparent"
						Command="{Binding GoToTicketsScreenCommand}"/>

			</StackPanel>
		</Border>

		<!-- MAIN CONTENT с ScrollViewer -->
		<ScrollViewer Grid.Row="2" Grid.Column="1"
					  Background="#F8F7F5"
					  Padding="40,30"
					  HorizontalScrollBarVisibility="Disabled"
					  VerticalScrollBarVisibility="Auto">

			<StackPanel Spacing="20" MaxWidth="700">

				<!-- Личные данные -->
				<Border Padding="24" Background="White" CornerRadius="12" BoxShadow="0 2 8 #1E000000">
					<StackPanel Spacing="16">
						<TextBlock Text="Личные данные" FontSize="18" FontWeight="SemiBold"/>
						<TextBox Watermark="Имя" Text="{Binding Name}" CornerRadius="8"/>
						<TextBox Watermark="Фамилия" Text="{Binding Surname}" CornerRadius="8"/>
						<TextBox Watermark="Отчество" Text="{Binding Patronymic}" CornerRadius="8"/>
						<TextBox Watermark="Телефон" Text="{Binding Phone}" CornerRadius="8"/>
						<TextBox Watermark="Email" Text="{Binding Email}" CornerRadius="8"/>

						<!-- Отдел -->
						<Grid ColumnDefinitions="260, 100">
							<ComboBox ItemsSource="{Binding Departments}"
									  SelectedItem="{Binding SelectedDepartment}"
									  PlaceholderText="Выберите отдел"
									  CornerRadius="8"
									  Width="250">
								<ComboBox.ItemTemplate>
									<DataTemplate>
										<TextBlock Text="{Binding Name}"/>
									</DataTemplate>
								</ComboBox.ItemTemplate>
							</ComboBox>
							<Button Grid.Column="1" Content="+" Width="30" Height="30" HorizontalAlignment="Left"
									Margin="8,0,0,0"
									ToolTip.Tip="Добавить новый отдел"
									Command="{Binding AddDepartmentCommand}"
									Background="#C9A86A" Foreground="White"
									HorizontalContentAlignment="Center"
									VerticalContentAlignment="Center"
									FontWeight="Bold"/>
						</Grid>

						<!-- Должность -->
						<Grid ColumnDefinitions="260, 100">
							<ComboBox ItemsSource="{Binding Positions}"
									  SelectedItem="{Binding SelectedPosition}"
									  PlaceholderText="Выберите должность"
									  CornerRadius="8"
									  Width="250">
								<ComboBox.ItemTemplate>
									<DataTemplate>
										<TextBlock Text="{Binding Name}"/>
									</DataTemplate>
								</ComboBox.ItemTemplate>
							</ComboBox>
							<Button Grid.Column="1" Content="+" Width="30" Height="30"
									Margin="8,0,0,0"
									ToolTip.Tip="Добавить новую должность"
									Command="{Binding AddPositionCommand}"
									Background="#C9A86A" Foreground="White"
									HorizontalContentAlignment="Center"
									VerticalContentAlignment="Center"
									FontWeight="Bold"/>
						</Grid>
					</StackPanel>
				</Border>

				<!-- Учётная запись -->
				<Border Padding="24" Background="White" CornerRadius="12" BoxShadow="0 2 8 #1E000000">
					<StackPanel Spacing="16">
						<TextBlock Text="Учётная запись" FontSize="18" FontWeight="SemiBold"/>
						<TextBox Watermark="Логин" Text="{Binding Login}" CornerRadius="8"/>
						<TextBox Watermark="Новый пароль (оставьте пустым чтобы не менять)"
								 Text="{Binding Password}" CornerRadius="8"/>
						<ComboBox ItemsSource="{Binding Roles}"
								  SelectedItem="{Binding SelectedRole}"
								  PlaceholderText="Выберите роль"
								  CornerRadius="8"
								  Width="280">
							<ComboBox.ItemTemplate>
								<DataTemplate>
									<TextBlock Text="{Binding Name}"/>
								</DataTemplate>
							</ComboBox.ItemTemplate>
						</ComboBox>
					</StackPanel>
				</Border>

				<!-- Кнопки действий -->
				<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16" Margin="0,20">
					<Button Content="Отмена"
							HorizontalContentAlignment="Center"
							VerticalContentAlignment="Center"
							CornerRadius="15"
							Width="130"
							Height="42"
							Command="{Binding CancelCommand}"/>

					<Button Content="{Binding SaveButtonText}"
							Width="160"
							Height="42"
							HorizontalContentAlignment="Center"
							VerticalContentAlignment="Center"
							CornerRadius="15"
							Background="#C9A86A"
							Foreground="White"
							Command="{Binding SaveCommand}"/>
				</StackPanel>

			</StackPanel>
		</ScrollViewer>
	</Grid>
</UserControl>