<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="DiplomHelpDeskOka.Views.AdminMainScreenView"
             xmlns:vm="clr-namespace:DiplomHelpDeskOka.ViewModels"
             x:DataType="vm:AdminMainScreenViewModel">
    <Grid RowDefinitions="Auto,Auto,*" ColumnDefinitions="200,*">
        <Border Grid.Row="0"
                Grid.ColumnSpan="2"
                Background="White"
                Height="70"
                Padding="20,10">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Лого -->
                <Image Source="/Assets/Image.png"
                       Height="40"/>
                <!-- Пользователь -->
                <StackPanel Grid.Column="2"
							HorizontalAlignment="Right"
							VerticalAlignment="Center"
							Orientation="Horizontal"
							Spacing="10">

					<StackPanel>
						<TextBlock Text="{Binding CurrentUser.ShortName}" FontWeight="SemiBold"/>
						<TextBlock Text="{Binding CurrentUser.Role.Name}" FontSize="12"/>
					</StackPanel>

					<Button Content="Выйти"
							Command="{Binding LogoutCommand}"
							Background="#D9534F"
							Foreground="White"
							Padding="10,5"/>
				</StackPanel>
            </Grid>
        </Border>
        <!-- 2. Золотая панель -->
        <Border Grid.Row="1"
                Grid.ColumnSpan="2"
                Background="#C9A86A"
                Height="60"
                Padding="20,0">
            <Grid ColumnDefinitions="200,*,*,*">
                <!-- Меню -->
                <TextBlock Text="Меню"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Foreground="White"
                           FontSize="16"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Главная"
                           Grid.Column="1"
                           Foreground="White"
                           FontSize="18"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontWeight="Bold"/>
                <TextBlock Text="{Binding TodayText}"
                           Grid.Column="2"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="18"
                           FontWeight="SemiBold"/>
                <!-- 🔥 ФИЛЬТР (Привязка к SelectedIndex) -->
                <ComboBox Grid.Column="3"
                          Width="120"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          VerticalContentAlignment="Center"
                          HorizontalContentAlignment="Center"
                          CornerRadius="20"
                          Background="White"
                          Foreground="#2B2B2B"
                          SelectedIndex="{Binding SelectedFilterIndex}">
                    <ComboBoxItem Content="Неделя"/>
                    <ComboBoxItem Content="Месяц"/>
                    <ComboBoxItem Content="Год"/>
                </ComboBox>
            </Grid>
        </Border>
        <!-- 📚 SIDEBAR -->
        <Border Grid.Row="2"
                Grid.Column="0"
                Background="#F1EFEA"
                Padding="10">
            <StackPanel Spacing="10">
                <!-- Active -->
                <Border Background="Transparent"
                        Padding="10"
                        BorderBrush="#C9A86A"
                        BorderThickness="3,0,0,0">
                    <Button Content="Главная"
                            Height="40"
                            Width="160"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Left"
                            VerticalContentAlignment="Center"
                            Background="Transparent"/>
                </Border>
                <Button Content="Пользователи"
                        Height="40"
                        Width="160"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        HorizontalContentAlignment="Left"
                        VerticalContentAlignment="Center"
                        Background="Transparent"
                        Command="{Binding GoToUsersCommand}"/>
                <Button Content="Заявки"
                        Height="40"
                        Width="160"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        HorizontalContentAlignment="Left"
                        VerticalContentAlignment="Center"
                        Background="Transparent"
                        Command="{Binding GoToTicketsScreenCommand}"/>
            </StackPanel>
        </Border>
       <!-- 📊 MAIN CONTENT -->
       <ScrollViewer Grid.Row="2"
                     Grid.Column="1"
                     Background="#F8F7F5"
                     Padding="32,24">
      
           <StackPanel Spacing="28">
      
               <!-- 🔢 Метрики -->
               <Border Background="White"
                       CornerRadius="16"
                       Padding="28"
                       BorderThickness="1"
                       BorderBrush="#EEEEEE">
      
                   <Grid ColumnDefinitions="*,*,*,*"
                         ColumnSpacing="20">
      
                       <!-- Просрочено -->
                       <Button Grid.Column="0"
                               Command="{Binding GoToFilteredTicketsCommand}"
                               CommandParameter="Overdue"
                               Background="Transparent"
                               BorderThickness="0"
                               Cursor="Hand">
                           <Border Background="#FDEBEC"
                                   CornerRadius="14"
                                   Padding="22">
                               <StackPanel HorizontalAlignment="Center" Spacing="8">
                                   <TextBlock Text="Просрочено"
                                              Foreground="#D64545"
                                              FontSize="14"
                                              FontWeight="Medium"
                                              HorizontalAlignment="Center"/>
                                   <TextBlock Text="{Binding OverdueCount}"
                                              FontSize="34"
                                              FontWeight="Bold"
                                              Foreground="#D64545"
                                              HorizontalAlignment="Center"/>
                               </StackPanel>
                           </Border>
                       </Button>
      
                       <!-- Новые -->
                       <Button Grid.Column="1"
                               Command="{Binding GoToFilteredTicketsCommand}"
                               CommandParameter="New"
                               Background="Transparent"
                               BorderThickness="0"
                               Cursor="Hand">
                           <Border Background="#E7F0FF"
                                   CornerRadius="14"
                                   Padding="22">
                               <StackPanel HorizontalAlignment="Center" Spacing="8">
                                   <TextBlock Text="Новые"
                                              Foreground="#2F6FED"
                                              FontSize="14"
                                              FontWeight="Medium"
                                              HorizontalAlignment="Center"/>
                                   <TextBlock Text="{Binding NewCount}"
                                              FontSize="34"
                                              FontWeight="Bold"
                                              Foreground="#2F6FED"
                                              HorizontalAlignment="Center"/>
                               </StackPanel>
                           </Border>
                       </Button>
      
                       <!-- В работе -->
                       <Button Grid.Column="2"
                               Command="{Binding GoToFilteredTicketsCommand}"
                               CommandParameter="InProgress"
                               Background="Transparent"
                               BorderThickness="0"
                               Cursor="Hand">
                           <Border Background="#FFF4E5"
                                   CornerRadius="14"
                                   Padding="22">
                               <StackPanel HorizontalAlignment="Center" Spacing="8">
                                   <TextBlock Text="В работе"
                                              Foreground="#D98E04"
                                              FontSize="14"
                                              FontWeight="Medium"
                                              HorizontalAlignment="Center"/>
                                   <TextBlock Text="{Binding InProgressCount}"
                                              FontSize="34"
                                              FontWeight="Bold"
                                              Foreground="#D98E04"
                                              HorizontalAlignment="Center"/>
                               </StackPanel>
                           </Border>
                       </Button>
      
                       <!-- Закрытые -->
                       <Button Grid.Column="3"
                               Command="{Binding GoToFilteredTicketsCommand}"
                               CommandParameter="Closed"
                               Background="Transparent"
                               BorderThickness="0"
                               Cursor="Hand">
                           <Border Background="#E6F6EC"
                                   CornerRadius="14"
                                   Padding="22">
                               <StackPanel HorizontalAlignment="Center" Spacing="8">
                                   <TextBlock Text="Закрыты"
                                              Foreground="#2E9B5F"
                                              FontSize="14"
                                              FontWeight="Medium"
                                              HorizontalAlignment="Center"/>
                                   <TextBlock Text="{Binding ClosedCount}"
                                              FontSize="34"
                                              FontWeight="Bold"
                                              Foreground="#2E9B5F"
                                              HorizontalAlignment="Center"/>
                               </StackPanel>
                           </Border>
                       </Button>
      
                   </Grid>
               </Border>
      
               <!-- ⚡ Быстрые действия -->
               <Grid ColumnDefinitions="*,*" ColumnSpacing="24" >
      
                   <Button Grid.Column="0"
                           Command="{Binding AddUserCommand}"
                           Background="White"
                           CornerRadius="16"
                           Height="128"
                           BorderThickness="1"
                           BorderBrush="#EEEEEE"
                           HorizontalAlignment="Stretch">
                       <StackPanel Orientation="Vertical"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Spacing="10">
                           <TextBlock Text="👤" FontSize="36" HorizontalAlignment="Center"/>
                           <TextBlock Text="Добавить сотрудника"
                                      FontSize="17"
                                      FontWeight="Medium"
                                      TextAlignment="Center"/>
                       </StackPanel>
                   </Button>
      
                   <Button Grid.Column="1"
                           Command="{Binding CreateTicketCommand}"
                           Background="White"
                           CornerRadius="16"
                           Height="128"
                           BorderThickness="1"
                           BorderBrush="#EEEEEE"
                           HorizontalAlignment="Stretch">
                       <StackPanel Orientation="Vertical"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Spacing="10">
                           <TextBlock Text="✍️" FontSize="36" HorizontalAlignment="Center"/>
                           <TextBlock Text="Создать заявку"
                                      FontSize="17"
                                      FontWeight="Medium"
                                      TextAlignment="Center"/>
                       </StackPanel>
                   </Button>
      
               </Grid>
      
               <!-- 📌 Недавние события -->
               <Border Background="White"
                       CornerRadius="16"
                       Padding="26"
                       BorderThickness="1"
                       BorderBrush="#EEEEEE"
                       MinHeight="220">

                   <StackPanel Spacing="18">
                       <TextBlock Text="Недавние события"
                                  FontSize="18"
                                  FontWeight="SemiBold"
                                  Foreground="#2B2B2B"/>

                       <ItemsControl ItemsSource="{Binding RecentEvents}">
                           <ItemsControl.ItemTemplate>
                               <DataTemplate>
                                   <Border Background="#FAF9F6"
                                           CornerRadius="10"
                                           Padding="16,14"
                                           Margin="0,6,0,0">
                                       <TextBlock Text="{Binding}"
                                                  FontSize="14.5"
                                                  Foreground="#444444"
                                                  TextWrapping="Wrap"/>
                                   </Border>
                               </DataTemplate>
                           </ItemsControl.ItemTemplate>
                       </ItemsControl>
                   </StackPanel>
               </Border>
           </StackPanel>
       </ScrollViewer>
    </Grid>
</UserControl>