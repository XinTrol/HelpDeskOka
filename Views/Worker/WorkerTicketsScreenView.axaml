<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
			 x:Class="DiplomHelpDeskOka.Views.WorkerTicketsScreenView"
			 xmlns:vm="clr-namespace:DiplomHelpDeskOka.ViewModels"
			 x:DataType="vm:WorkerTicketsScreenViewModel">

	<Grid RowDefinitions="Auto, Auto, *" ColumnDefinitions="200, *">
		<!-- Top Header -->
		<Border Grid.Row="0" Grid.ColumnSpan="2" Background="White" Height="70" Padding="20,10">
			<Grid ColumnDefinitions="Auto, *, Auto">
				<Image Source="/Assets/Image.png" Height="40"/>
				<StackPanel Grid.Column="2"
							HorizontalAlignment="Right"
							VerticalAlignment="Center"
							Orientation="Horizontal"
							Spacing="10">

					<StackPanel>
						<TextBlock Text="{Binding CurrentUser.ShortName}" FontWeight="SemiBold"/>
						<TextBlock Text="{Binding CurrentUser.Role.Name}" FontSize="12"/>
					</StackPanel>

					<Button Content="Выйти"
							Command="{Binding LogoutCommand}"
							Background="#D9534F"
							Foreground="White"
							Padding="10,5"/>
				</StackPanel>
			</Grid>
		</Border>

		<!-- Menu Bar -->
		<Border Grid.Row="1" Grid.ColumnSpan="2" Background="#C9A86A" Height="60" Padding="20,0">
			<Grid ColumnDefinitions="200, *, Auto">
				<TextBlock Grid.Column="0"
						   Text="Меню"
						   VerticalAlignment="Center"
						   Foreground="White"
						   FontSize="16"
						   FontWeight="SemiBold"/>

				<!-- Toggle between Department / My Tickets -->
				<StackPanel Grid.Column="1"
							Orientation="Horizontal"
							HorizontalAlignment="Center"
							Spacing="10">
					<Button Content="Заявки отдела"
							Command="{Binding ShowDepartmentTicketsCommand}"
							Padding="12,5"
							Background="White"
							CornerRadius="15"/>

					<Button Content="Мои заявки"
							Command="{Binding ShowMyTicketsListCommand}"
							Padding="12,5"
							Background="White"
							CornerRadius="15"/>
				</StackPanel>
			</Grid>
		</Border>

		<!-- Left Sidebar -->
		<Border Grid.Row="2" Grid.Column="0" Background="#F1EFEA" Padding="10">
			<StackPanel Spacing="10">
				<Border Background="Transparent" Padding="10"
						BorderBrush="#C9A86A" BorderThickness="3,0,0,0">
					<Button Content="Заявки" Height="40" Width="160"
							HorizontalAlignment="Left"
							HorizontalContentAlignment="Left"
							VerticalContentAlignment="Center"
							Background="Transparent"/>
				</Border>
			</StackPanel>
		</Border>

		<!-- Main Content -->
		<Grid Grid.Row="2" Grid.Column="1" RowDefinitions="Auto, *">
			<!-- Filters -->
			<Grid Grid.Row="0" ColumnDefinitions="*, Auto, Auto, Auto, Auto, Auto, Auto, Auto" Margin="10">
				<TextBox Grid.Column="0" Height="38"
						 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
						 Watermark="Поиск по названию / описанию"
						 Margin="10,0,10,0"
						 VerticalContentAlignment="Center"/>

				<ComboBox Grid.Column="1" Width="120" Height="38" Margin="0,0,10,0"
						  ItemsSource="{Binding Statuses}"
						  SelectedItem="{Binding SelectedStatus}"
						  PlaceholderText="Статус"
						  DisplayMemberBinding="{Binding Name}"/>

				<ComboBox Grid.Column="2" Width="120" Height="38" Margin="0,0,10,0"
						  ItemsSource="{Binding Priorities}"
						  SelectedItem="{Binding SelectedPriority}"
						  PlaceholderText="Приоритет"
						  DisplayMemberBinding="{Binding Name}"/>

				<ComboBox Grid.Column="3" Width="140" Height="38" Margin="0,0,10,0"
						  ItemsSource="{Binding Types}"
						  SelectedItem="{Binding SelectedType}"
						  PlaceholderText="Тип"
						  DisplayMemberBinding="{Binding Name}"/>

				<Button Grid.Column="5" Height="38" Content="Сбросить фильтры"
						Background="#D4B36A" Foreground="White"
						Command="{Binding ResetFiltersCommand}"
						VerticalContentAlignment="Center"
						Margin="0,0,10,0"/>

				<Button Grid.Column="6" Height="38" Width="42" Background="#4CAF50"
						Foreground="White" FontSize="22" FontWeight="Bold"
						Content="+"
						HorizontalContentAlignment="Center"
						VerticalContentAlignment="Center"
						Command="{Binding CreateTicketCommand}"
						Margin="0,0,10,0"/>
			</Grid>

			<!-- DataGrid -->
			<DataGrid Grid.Row="1"
					  ItemsSource="{Binding Tickets}"
					  AutoGenerateColumns="False"
					  IsReadOnly="True"
					  CanUserResizeColumns="True"
					  CanUserSortColumns="True"
					  Background="White"
					  BorderBrush="#E0E0E0"
					  BorderThickness="1"
					  CornerRadius="12"
					  Margin="20,10,20,20"
					  RowHeight="54"
					  GridLinesVisibility="None">

				<!-- Стили строк и заголовков -->
				<DataGrid.Styles>
					<Style Selector="DataGridRow">
						<Setter Property="Height" Value="54"/>
					</Style>
					<Style Selector="DataGridRow:pointerover">
						<Setter Property="Background" Value="#F8F7F5"/>
					</Style>
					<Style Selector="DataGridRow:selected">
						<Setter Property="Background" Value="#F0EDE6"/>
					</Style>

					<!-- Стиль заголовков -->
					<Style Selector="DataGridColumnHeader">
						<Setter Property="Background" Value="#F8F7F5"/>
						<Setter Property="Foreground" Value="#2B2B2B"/>
						<Setter Property="FontWeight" Value="SemiBold"/>
						<Setter Property="FontSize" Value="14"/>
						<Setter Property="Padding" Value="12,10"/>
						<Setter Property="BorderBrush" Value="#E0E0E0"/>
						<Setter Property="BorderThickness" Value="0,0,0,1"/>
					</Style>

					<Style Selector="DataGridColumnHeader TextBlock">
						<Setter Property="TextAlignment" Value="Center"/>
						<Setter Property="VerticalAlignment" Value="Center"/>
					</Style>
				</DataGrid.Styles>

				<DataGrid.Columns>

					<DataGridTextColumn Header="№"
										Binding="{Binding Id}"
										Width="75" />

					<DataGridTextColumn Header="Название заявки"
										Binding="{Binding Title}"
										Width="*"
										MinWidth="320" />

					<DataGridTextColumn Header="Тип"
										Binding="{Binding TicketType.Name}"
										Width="Auto"
										MinWidth="115" />

					<DataGridTextColumn Header="Статус"
										Binding="{Binding Status.Name}"
										Width="Auto"
										MinWidth="115" />

					<DataGridTextColumn Header="Приоритет"
										Binding="{Binding Priority.Name}"
										Width="Auto"
										MinWidth="105" />

					<DataGridTextColumn Header="Отдел"
										Binding="{Binding Department.Name}"
										Width="Auto"
										MinWidth="130" />

					<DataGridTextColumn Header="Автор"
										Binding="{Binding Author.ShortName}"
										Width="Auto"
										MinWidth="150" />

					<!-- Действия -->
					<DataGridTemplateColumn Header="Действия" Width="92">
						<DataGridTemplateColumn.CellTemplate>
							<DataTemplate>
								<Button Content="✏️"
										ToolTip.Tip="Редактировать"
										Width="38"
										Height="38"
										Background="Transparent"
										BorderThickness="0"
										HorizontalAlignment="Center"
										VerticalAlignment="Center"
										Command="{Binding $parent[DataGrid].DataContext.EditTicketCommand}"
										CommandParameter="{Binding}"/>
							</DataTemplate>
						</DataGridTemplateColumn.CellTemplate>
					</DataGridTemplateColumn>

				</DataGrid.Columns>
			</DataGrid>
		</Grid>
	</Grid>
</UserControl>